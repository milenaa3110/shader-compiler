{
  "version": 4,
  "configurations": [
    {
      "name": "Linux",
      "compilerPath": "/usr/bin/clang++",
      "cppStandard": "c++20",
      "intelliSenseMode": "linux-clang-x64",
      "includePath": [
        "${workspaceFolder}/**",
        "/usr/lib/llvm-18/include",
        "/usr/include"
      ],
      "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}",
        "--background-index",
        "--clang-tidy"
      ]
    }
  ]
}
