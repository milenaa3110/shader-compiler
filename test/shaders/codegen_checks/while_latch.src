# IR regression: a `while` loop must route its back-edge through a dedicated
# `while.latch` block (not branch the body straight back to `while.cond`).
# Without the separate latch, a nested loop's inner merge block doubles as the
# outer loop's back-edge source, which SPIR-V's structured CFG rejects (a block
# cannot be both an inner construct's merge and an outer construct's continue).
# The latch keeps each loop's continue target distinct, so the SPIR-V emitter
# can attach a valid OpLoopMerge.

out vec4 FragColor;

@entry @stage(fragment)
fn void main() {
    float s = 0.0;
    int i = 0;
    while (i < 3) {
        s = s + 1.0;
        i = i + 1;
    }
    FragColor = vec4(s, s, s, s);
}

# CHECK: while.cond:
# CHECK: while.body:
# CHECK: while.latch:
# CHECK-NEXT: br label %while.cond
