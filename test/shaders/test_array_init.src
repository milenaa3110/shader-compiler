# test_array_init.src - array declaration and element access (bug fix: ArrayInitExprAST::codegen)

fn vec4 shade(vec2 uv) {
    # array without initializer (zero-initialized)
    float zeros[4];

    # array with initializer - this was the bug: used to return null
    float weights[4] = { 0.1, 0.3, 0.5, 0.1 };

    # read elements back
    float w0 = weights[0];
    float w1 = weights[1];
    float w2 = weights[2];
    float w3 = weights[3];

    # use values so they aren't optimized away
    float total = w0 + w1 + w2 + w3;

    # array of vec3
    vec3 palette[2] = { vec3(1.0, 0.0, 0.0), vec3(0.0, 0.0, 1.0) };
    vec3 c0 = palette[0];
    vec3 c1 = palette[1];

    float t = uv.x;
    float r = c0.x + (c1.x - c0.x) * t;
    float b = c0.z + (c1.z - c0.z) * t;

    return vec4(r * total, 0.0, b * total, 1.0);
}
