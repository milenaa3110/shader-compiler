# voronoi_fs.src — Animated Voronoi cells (9 moving sites)
# Tests: nested loops, sqrt, distance computation on RVV

uniform float uTime;
in vec2 vUV;
out vec4 FragColor;

@entry @stage(fragment)
fn void main() {
    float u = vUV.x;
    float v = vUV.y;

    float minDist  = 9999.0;
    float minDist2 = 9999.0;
    float siteR    = 0.0;
    float siteG    = 0.0;

    # 9 animated sites
    for (float i = 0.0; i < 3.0; i = i + 1.0) {
        for (float j = 0.0; j < 3.0; j = j + 1.0) {
            float phase = i * 1.1 + j * 0.7;
            float sx = (i + 1.0) * 0.25 + 0.08 * sin(uTime * 0.7 + phase);
            float sy = (j + 1.0) * 0.25 + 0.08 * cos(uTime * 0.9 + phase * 1.3);
            float dx = u - sx;
            float dy = v - sy;
            float d  = sqrt(dx * dx + dy * dy);

            if (d < minDist) {
                minDist2 = minDist;
                minDist  = d;
                siteR = 0.5 + 0.5 * sin(phase + uTime * 0.3);
                siteG = 0.5 + 0.5 * cos(phase * 1.7 + uTime * 0.2);
            }
        }
    }

    float edge = smoothstep(0.0, 0.015, minDist2 - minDist);
    float siteB = 0.5 + 0.5 * cos(siteR * 3.14 + uTime);

    FragColor = vec4(siteR * edge, siteG * edge, siteB * edge, 1.0);
}