# blur_cs.src — 5-tap horizontal Gaussian blur (separable pass) on RGBA float image.
# Compiled by irgen_spirv to build/spirv/blur.comp.spv.
#
# binding 0 = input  vec4 buffer (W*H pixels, row-major)
# binding 1 = output vec4 buffer
# push constants: width, height
# workgroup: 16×16
# Kernel: [1, 4, 6, 4, 1] / 16  (applied in X)
#
# GPU path: dispatched as compute shader via vk_host_compute_blur.
# CPU path: blur_cs.src is also compiled via irgen_riscv for the RISC-V benchmark.

layout(binding=0) uniform uint width;
layout(binding=1) uniform uint height;

layout(std430, binding=0) readonly  buffer vec4 src[];
layout(std430, binding=1) writeonly buffer vec4 dst[];

@entry @stage(compute) @workgroup_size(16, 16, 1)
fn void main() {
    uint x = gl_GlobalInvocationID.x;
    uint y = gl_GlobalInvocationID.y;
    if (x >= width || y >= height) return;

    uint W = width;

    # Clamp-to-edge for border pixels
    uint xm2 = x > uint(1)        ? x - uint(2) : uint(0);
    uint xm1 = x > uint(0)        ? x - uint(1) : uint(0);
    uint xp1 = x + uint(1) < W    ? x + uint(1) : W - uint(1);
    uint xp2 = x + uint(2) < W    ? x + uint(2) : W - uint(1);

    vec4 a = src[y * W + xm2];
    vec4 b = src[y * W + xm1];
    vec4 c = src[y * W + x  ];
    vec4 d = src[y * W + xp1];
    vec4 e = src[y * W + xp2];

    dst[y * W + x] = (a + e) * 0.0625 + (b + d) * 0.25 + c * 0.375;
}
