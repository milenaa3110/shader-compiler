# life_cs.src — Conway's Game of Life, one generation per dispatch.
# Compiled by irgen_spirv to build/spirv/life.comp.spv.
#
# binding 0 = read grid (src), binding 1 = write grid (dst)
# push constants: width, height
# workgroup: 16×16

layout(binding=0) uniform uint width;
layout(binding=1) uniform uint height;

layout(std430, binding=0) readonly  buffer uint src[];
layout(std430, binding=1) writeonly buffer uint dst[];

@entry @stage(compute) @workgroup_size(16, 16, 1)
fn void main() {
    uint x = gl_GlobalInvocationID.x;
    uint y = gl_GlobalInvocationID.y;
    if (x >= width || y >= height) return;

    uint W = width;
    uint H = height;

    # Count live neighbours (8-connected, wrap-around via modulo)
    uint alive = uint(0);

    uint xm1 = (x + W - uint(1)) % W;
    uint xp1 = (x + uint(1)) % W;
    uint ym1 = (y + H - uint(1)) % H;
    uint yp1 = (y + uint(1)) % H;

    alive = alive + src[ym1 * W + xm1];
    alive = alive + src[ym1 * W + x  ];
    alive = alive + src[ym1 * W + xp1];
    alive = alive + src[y   * W + xm1];
    alive = alive + src[y   * W + xp1];
    alive = alive + src[yp1 * W + xm1];
    alive = alive + src[yp1 * W + x  ];
    alive = alive + src[yp1 * W + xp1];

    uint cell = src[y * W + x];
    # Conway rules: live cell survives with 2 or 3 neighbours;
    #               dead cell is born with exactly 3 neighbours.
    uint next = ((cell == uint(1) && (alive == uint(2) || alive == uint(3))) ||
                 (cell == uint(0) &&  alive == uint(3))) ? uint(1) : uint(0);
    dst[y * W + x] = next;
}
