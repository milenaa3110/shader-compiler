# diverge_fs.src — SIMD divergence benchmark (CPU/RISC-V side)
# Counterpart to test/shaders/spirv_vulkan/diverge.frag.
#
# Left half  (x < 0.5): trivial 4-op sine wave.
# Right half (x >= 0.5): 96-iteration Mandelbrot.
#
# CPU ADVANTAGE: each RISC-V thread takes exactly its own branch.
# There is no SIMD register group — threads are truly independent.
# A pixel on the left executes 4 instructions; one on the right executes ~768.
# With OpenMP, all CPU cores run their own pixels with no cross-thread stalling.
#
# GPU PENALTY: warp lanes on the left must idle while right-side lanes iterate.
# The boundary region (warps spanning x=0.5) pays full 96-iteration cost for all lanes.
# This narrows the GPU speedup compared to uniform shaders.

uniform float uTime;
in vec2 vUV;
out vec4 FragColor;

@entry @stage(fragment)
fn void main() {
    float val = 0.0;

    if (vUV.x < 0.5) {
        # ── Light path: 4 cheap trig ops ──────────────────────────────────────
        float u = vUV.x * 2.0;
        val = sin(u * 31.4159 + uTime * 1.7) * 0.5 + 0.5;
        val = val * (cos(vUV.y * 25.1327 + uTime * 0.9) * 0.5 + 0.5);
    } else {
        # ── Heavy path: 96-iteration Mandelbrot ────────────────────────────────
        float u = (vUV.x - 0.5) * 2.0;
        float zoom = exp(-uTime * 0.08 + 0.5);
        float cx = (u - 0.5) * 3.5 * zoom - 0.7436;
        float cy = (vUV.y - 0.5) * 3.5 * zoom + 0.1319;
        float zx = 0.0;
        float zy = 0.0;
        float iter = 0.0;
        for (float i = 0.0; i < 96.0; i = i + 1.0) {
            if (zx * zx + zy * zy < 4.0) {
                float nx = zx * zx - zy * zy + cx;
                zy = 2.0 * zx * zy + cy;
                zx = nx;
                iter = i + 1.0;
            }
        }
        val = iter / 96.0;
    }

    float t = val + uTime * 0.1;
    float r = 0.5 + 0.5 * cos(t * 6.2832 + 0.0);
    float g = 0.5 + 0.5 * cos(t * 6.2832 + 2.09);
    float b = 0.5 + 0.5 * cos(t * 6.2832 + 4.19);
    FragColor = vec4(r, g, b, 1.0);
}
