# terrain_vs_vk.src — Animated wave terrain vertex shader (Vulkan/SPIR-V build)
# Identical to terrain_vs.src but gl_Position.y is negated for Vulkan NDC
# (Vulkan y=+1 is bottom; RISC-V software rasterizer flips y internally).

uniform float uTime;
out vec4 vColor;

@entry @stage(vertex)
fn void main() {
    float GRID = 32.0;
    float vid = float(gl_VertexID);
    float quadIdx = floor(vid / 6.0);
    float corner  = vid - quadIdx * 6.0;

    float gx = floor(quadIdx / GRID);
    float gz = quadIdx - gx * GRID;

    float dx = 0.0;
    float dz = 0.0;
    if (corner == 1.0 || corner == 2.0 || corner == 4.0) { dx = 1.0; }
    if (corner == 2.0 || corner == 4.0 || corner == 5.0) { dz = 1.0; }

    float fx = (gx + dx) / GRID * 4.0 - 2.0;
    float fz = (gz + dz) / GRID * 4.0 - 2.0;

    float fy = sin(fx * 1.9 + uTime * 1.1) * cos(fz * 2.4 + uTime * 0.85) * 0.32
             + sin(fx * 4.2 + fz * 3.3 + uTime * 1.6) * 0.13
             + cos(sqrt(fx*fx + fz*fz) * 2.8 - uTime * 2.1) * 0.09;

    float r = sqrt(fx*fx + fz*fz) + 0.001;
    float dydx = cos(fx * 1.9 + uTime * 1.1) * 1.9 * 0.32
               + cos(fx * 4.2 + fz * 3.3 + uTime * 1.6) * 4.2 * 0.13
               - (fx / r) * 2.8 * sin(r * 2.8 - uTime * 2.1) * 0.09;
    float dydz = -sin(fz * 2.4 + uTime * 0.85) * 2.4 * 0.32
               + cos(fx * 4.2 + fz * 3.3 + uTime * 1.6) * 3.3 * 0.13
               - (fz / r) * 2.8 * sin(r * 2.8 - uTime * 2.1) * 0.09;

    float nLen = sqrt(dydx*dydx + 1.0 + dydz*dydz);
    float nxV = -dydx / nLen;
    float nyV =  1.0  / nLen;
    float nzV = -dydz / nLen;

    float sunX = 0.5; float sunY = 0.8; float sunZ = 0.3;
    float sLen = sqrt(sunX*sunX + sunY*sunY + sunZ*sunZ);
    float diff = clamp(nxV*sunX/sLen + nyV*sunY/sLen + nzV*sunZ/sLen, 0.0, 1.0);
    float light = diff * 0.75 + 0.25;

    float h = clamp((fy + 0.5) / 1.0, 0.0, 1.0);
    float isWater = step(h, 0.28);
    float isSnow  = step(0.70, h);
    float isLand  = 1.0 - isWater - isSnow;

    float cr = isWater*0.08 + isLand*(0.18 + h*0.38) + isSnow*0.93;
    float cg = isWater*0.32 + isLand*(0.52 + h*0.12) + isSnow*0.94;
    float cb = isWater*0.72 + isLand*0.17 + isSnow*0.98;

    vColor = vec4(cr*light, cg*light, cb*light, 1.0);

    float camAngle = uTime * 0.18;
    float camX = sin(camAngle) * 5.0;
    float camY = 3.2;
    float camZ = cos(camAngle) * 5.0;

    float fLen = sqrt(camX*camX + camY*camY + camZ*camZ);
    float fwdX = -camX/fLen;
    float fwdY = -camY/fLen;
    float fwdZ = -camZ/fLen;

    float rX = fwdZ;
    float rZ = -fwdX;
    float rLen = sqrt(rX*rX + rZ*rZ);
    rX = rX/rLen;
    rZ = rZ/rLen;

    float upX = -rZ*fwdY;
    float upY =  rZ*fwdX - rX*fwdZ;
    float upZ =  rX*fwdY;

    float dvX = fx - camX;
    float dvY = fy - camY;
    float dvZ = fz - camZ;

    float cx = rX*dvX + 0.0*dvY + rZ*dvZ;
    float cy = upX*dvX + upY*dvY + upZ*dvZ;
    float cz = fwdX*dvX + fwdY*dvY + fwdZ*dvZ;

    float f = 1.732;
    # Vulkan NDC: negate y; z maps to [0,1] (near=0.1, far=20):
    #   A = far/(far-near) = 1.00503, B = -far*near/(far-near) = -0.10050
    gl_Position = vec4(f*cx, -(f*cy), 1.00503*cz - 0.10050, cz);
}
