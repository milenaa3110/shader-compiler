# test_basic.src - arithmetic, control flow, while, for, swizzle reads

fn vec4 shade(vec2 uv) {
    float x = uv.x;
    float y = uv.y;

    # arithmetic
    float sum  = x + y;
    float diff = x - y;
    float prod = x * y;
    float quot = sum / 2.0;

    # unary
    float neg = -quot;

    # comparison and if/else
    float r = 0.0;
    if (x > 0.5) {
        r = 1.0;
    } else {
        r = 0.0;
    }

    # while loop
    float acc = 0.0;
    float i   = 0.0;
    while (i < 4.0) {
        acc = acc + 0.1;
        i   = i + 1.0;
    }

    # for loop
    float fsum = 0.0;
    for (float j = 0.0; j < 3.0; j = j + 1.0) {
        fsum = fsum + j;
    }

    # logical operators (short-circuit)
    bool cond = (x > 0.0) && (y > 0.0);
    float g = 0.0;
    if (cond) {
        g = 1.0;
    }

    # swizzle read
    vec3 rgb = vec3(r, g, acc);
    float bval = rgb.z;

    return vec4(r, g, bval, 1.0);
}
