# test_ternary.src — right-associativity of `?:`.
#
# Both the then- and else-branches contain a nested ternary so the parser
# can't accidentally regress to left-associativity in *either* direction.
# Right-associative means:
#   a ? b ? c : d : e   parses as   a ? (b ? c : d) : e
#   a ? b : c ? d : e   parses as   a ? b : (c ? d : e)
# Hard to write a runtime-only oracle for associativity in a shader; the
# real signal is that this compiles cleanly. A wrong-associative parse
# would slot the inner `:` to the outer `?` and throw "Expected ':'".

fn vec4 shade(vec2 uv) {
    float x = uv.x;
    float y = uv.y;

    # nested in the THEN branch
    float a = (x > 0.0) ? (y > 0.0) ? 1.0 : 2.0 : 3.0;

    # nested in the ELSE branch
    float b = (x > 0.0) ? 4.0 : (y > 0.0) ? 5.0 : 6.0;

    # both at once
    float c = (x > 0.0) ? (y > 0.0) ? 7.0 : 8.0
                        : (y > 0.0) ? 9.0 : 10.0;

    return vec4(a, b, c, 1.0);
}
