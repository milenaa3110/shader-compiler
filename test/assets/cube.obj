# Simple unit cube centered at origin, 12 triangles, with face normals.
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

vn  0  0 -1
vn  0  0  1
vn  0 -1  0
vn  0  1  0
vn -1  0  0
vn  1  0  0

# back (-Z)
f 1//1 3//1 2//1
f 1//1 4//1 3//1
# front (+Z)
f 5//2 6//2 7//2
f 5//2 7//2 8//2
# bottom (-Y)
f 1//3 2//3 6//3
f 1//3 6//3 5//3
# top (+Y)
f 4//4 7//4 3//4
f 4//4 8//4 7//4
# left (-X)
f 1//5 5//5 8//5
f 1//5 8//5 4//5
# right (+X)
f 2//6 3//6 7//6
f 2//6 7//6 6//6
